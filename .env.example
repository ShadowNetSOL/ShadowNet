# ═════════════════════════════════════════════════════════════════════
# ShadowNet — environment configuration
# Copy to .env and fill in. Never commit .env.
# ═════════════════════════════════════════════════════════════════════

# ─── BROWSER-EXPOSED (must be VITE_-prefixed; bundled into client) ─────
# Origin of the api-server. In Railway/prod this is the same origin so "/api"
# works; only set the explicit URL when the SPA and api are split.
VITE_API_BASE=/api

# Default slippage applied if the user doesn't override (1% = 100 bps).
VITE_DEFAULT_SLIPPAGE_BPS=100

# ─── SOLANA RPC (server-side, READ ops) ────────────────────────────
# CRITICAL: Use a regular Helius/QuickNode mainnet RPC, NOT a sender-only
# endpoint. The Helius sender (sender.helius-rpc.com) is WRITE-ONLY and
# will break getSlot / getRecentPerformanceSamples / getBalance.
SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Helius API key used by the holder-tier check (api-server/src/lib/entitlement.ts).
# Just the key, no URL — the entitlement code prepends the Helius mainnet URL.
# Required when ENTITLEMENT_DISABLED is unset/false.
HELIUS_API_KEY=

# ─── JUPITER ULTRA SWAP API (server-side) ────────────────────────
# Get a free key at https://portal.jup.ag — required for the Ultra v1 API.
# Without this, /api/swap/quote and /api/swap/execute will fall back to
# rate-limited public endpoints and may not land tx in <2s.
# NOTE: lite-api.jup.ag is being deprecated 2025-12-31.
JUPITER_API_KEY=

# ─── PLATFORM FEE ROUTING (server-side) ────────────────────────
# How fees actually reach you:
#   On every quote, the server attaches `feeAccount` (matching the OUTPUT
#   token mint) and `platformFeeBps`. Jupiter takes the BPS off the output
#   leg and DEPOSITS THE FEE INTO YOUR fee-account inside the same swap
#   transaction. Zero retention; settlement is atomic with the trade.
#
# 1) Generate a fresh keypair → this is your FEE_WALLET (the owner).
# 2) From FEE_WALLET, create three Associated Token Accounts (ATAs):
#       - wSOL ATA  → FEE_ACCOUNT_WSOL
#       - USDC ATA  → FEE_ACCOUNT_USDC
#       - USDT ATA  → FEE_ACCOUNT_USDT
#    Use `spl-token create-account <MINT> --owner <FEE_WALLET>` or any wallet
#    that supports ATA creation. ATAs are deterministic; once created they
#    cost 0 to receive into.
# 3) Fill in the addresses below. Trades against output mints with no ATA
#    here will simply skip the fee (users still trade normally).

FEE_WALLET=
FEE_ACCOUNT_WSOL=
FEE_ACCOUNT_USDC=
FEE_ACCOUNT_USDT=

# Cold-storage destination you sweep accumulated fees to. Optional — only
# referenced by future treasury-rotation jobs.
TREASURY_WALLET=

# Platform fee in basis points (100 = 1%, 50 = 0.5%, 255 = max allowed by Jupiter).
PLATFORM_FEE_BPS=100

# ─── HOLDER-TIER GATING (server-side) ───────────────────────────
# Used by /api/auth/verify-holder. The flow:
#   1. Frontend asks user wallet to sign a nonce challenge.
#   2. Server verifies signature, then queries Helius for the wallet's
#      balance of ENTITLEMENT_MINT. If balance ≥ ENTITLEMENT_MIN_BALANCE,
#      a 15-min HMAC-signed claim is issued (signed with CLAIM_SIGNING_KEY).
#   3. Frontend stores the claim in localStorage and sends it on later calls.
#
# Pre-launch shortcut: set ENTITLEMENT_DISABLED=true and the on-chain check
# is skipped — every signature-verified wallet gets the holder claim. Use
# this until you have a real token to gate against.
ENTITLEMENT_DISABLED=false

# Base58 SPL mint address that gates the holder tier. Required when
# ENTITLEMENT_DISABLED is false/unset.
ENTITLEMENT_MINT=

# Minimum balance in UI units. Defaults to 1 if unset.
ENTITLEMENT_MIN_BALANCE=1

# HMAC secret used to sign holder claims (any ≥16-char random string).
# REQUIRED in prod — if unset, the server falls back to an in-memory key
# that resets on every restart, booting all signed-in users.
# Generate with: openssl rand -base64 32
CLAIM_SIGNING_KEY=

# ─── DATA ENRICHMENT (server-side, optional) ───────────────────────
# Birdeye is used to enrich the top-15 ranked tokens with real holder counts.
# https://birdeye.so → API portal. Without a key, holder column reads 0.
BIRDEYE_API_KEY=

# DexScreener public endpoints work unauthenticated — no key required for
# the live feed. Set this only if you have an enterprise plan.
DEXSCREENER_API_KEY=

# GeckoTerminal public OHLCV is unauthenticated. Set only for higher quotas.
GECKOTERMINAL_API_KEY=

# ─── ADMIN ────────────────────────────────────────────────────────────
ADMIN_KEY=

# ─── PORT ──────────────────────────────────────────────────────────────
PORT=8080
