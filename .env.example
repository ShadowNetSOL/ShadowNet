# ──────────────────────────────────────────────────────────────────────────
  # ShadowNet — environment variables
  #
  # This file is the AUTHORITATIVE reference for every variable consumed by
  # ShadowNet's API server. If you add a new process.env.<VAR> reference in
  # code, add it here too.
  #
  # Variables are grouped by capability. Required ones are flagged. Anything
  # without a "REQUIRED" tag is optional, with a sensible default or a
  # graceful no-op when unset.
  # ──────────────────────────────────────────────────────────────────────────


  # ── Runtime ───────────────────────────────────────────────────────────────

  # REQUIRED. Port the API server binds to. Injected by Railway / Replit.
  PORT=3000

  # Optional. Override where the production server expects to find the built
  # frontend. Used in dev only; production reads from dist/public.
  # STATIC_DIR=/absolute/path/to/built/spa


  # ── Region descriptor ─────────────────────────────────────────────────────
  # One Railway service equals one outbound IP equals one region.
  # These describe THIS instance's region. See RELAY.md for the full schema.

  RELAY_REGION=us-east
  RELAY_REGION_NAME=US East
  RELAY_REGION_COUNTRY=US
  RELAY_REGION_CITY=New York
  RELAY_REGION_TZ=America/New_York
  RELAY_REGION_LOCALE=en-US

  # Optional. Lead-instance only. JSON array of additional region descriptors.
  # Each entry has the same shape as the variables above plus a proxyUrl
  # field pointing at that peer's public URL. See RELAY.md for examples.
  # RELAY_PEERS=[{"id":"eu-west","name":"EU West","country":"Germany","countryCode":"DE","city":"Frankfurt","timezone":"Europe/Berlin","locale":"de-DE","proxyUrl":"https://eu-west.shadownet.network","noLogs":true}]


  # ── Holder-tier authentication ────────────────────────────────────────────
  # Required for the holder tier (remote-browser pool access). Without these,
  # the server still boots and serves the proxy tier; holder-tier requests
  # return an honest "not configured" payload.

  # Helius mainnet API key. Used to verify SPL balance for holder claims.
  HELIUS_API_KEY=

  # SPL mint address that gates the holder tier.
  ENTITLEMENT_MINT=

  # Minimum balance (in token UI units) to qualify. Defaults to 1.
  ENTITLEMENT_MIN_BALANCE=1

  # REQUIRED IN PRODUCTION. HMAC-signing secret for holder claim tokens.
  # Minimum 16 bytes. In dev a process-lifetime key is generated automatically;
  # never rely on that in production.
  CLAIM_SIGNING_KEY=

  # Dev escape hatch. When "true", skips the on-chain check and grants the
  # holder tier to any signature-verified wallet. Pre-launch / dev only.
  # NEVER set this in production.
  # ENTITLEMENT_DISABLED=false


  # ── Trading and Jupiter Ultra swap ────────────────────────────────────────
  # Required for the trading terminal and chart pages.

  # Solana mainnet RPC for trading-side reads (Helius / QuickNode / similar).
  SOLANA_RPC=

  # Solana mainnet RPC for the intelligence-side reads. Can point at the
  # same provider as SOLANA_RPC; kept distinct so trading can be rate-limited
  # separately if needed.
  SOLANA_RPC_URL=

  # Jupiter Ultra Swap API key (portal.jup.ag).
  JUPITER_API_KEY=

  # Platform-fee receiver pubkey. The wallet that owns the fee ATAs below.
  FEE_WALLET=

  # Pre-created associated token accounts on FEE_WALLET for each fee mint.
  FEE_ACCOUNT_WSOL=
  FEE_ACCOUNT_USDC=
  FEE_ACCOUNT_USDT=

  # Platform fee in basis points. Defaults to 100 (1%). Capped server-side at
  # 255 (Jupiter Ultra contract maximum).
  PLATFORM_FEE_BPS=100


  # ── Intel Hub ─────────────────────────────────────────────────────────────

  # X (Twitter) API v2 app-only Bearer token. Required for the X CA Checker.
  TWITTER_API_BEARER=

  # GitHub personal access token. Public-repo read scope is sufficient.
  GITHUB_TOKEN=

  # OpenAI API key for AI-assisted intelligence classification. If you use
  # the Replit AI Integrations proxy, set AI_INTEGRATIONS_OPENAI_API_KEY
  # instead and the integration will route through Replit's proxy.
  OPENAI_API_KEY=
  # OPENAI_BASE_URL=https://api.openai.com/v1
  # AI_INTEGRATIONS_OPENAI_API_KEY=
  # AI_INTEGRATIONS_OPENAI_BASE_URL=

  # Optional. Pin a specific OpenAI model id (e.g. gpt-4o-mini).
  # AI_MODEL=gpt-4o-mini


  # ── Remote-browser pool ───────────────────────────────────────────────────
  # Required for the holder-tier remote browser. The pool is a separately
  # operated service; see SECURITY.md for the hard isolation contract any
  # compliant pool implementation must satisfy.

  REMOTE_BROWSER_POOL_URL=
  REMOTE_BROWSER_POOL_TOKEN=


  # ── Orchestrator overrides ────────────────────────────────────────────────

  # Comma-separated list of hostnames that always escalate to the remote
  # tier, regardless of failure history or precheck verdict. Useful for
  # operator-known hard-gated destinations.
  # FORCE_REMOTE_FOR_HOSTS=app.uniswap.org,nfts.example.com


  # ── Operator metrics ──────────────────────────────────────────────────────

  # Bearer token for /api/admin/metrics and /api/admin/reset. Without this,
  # both endpoints return 503.
  ADMIN_TOKEN=
  